{
  "name": "backend",
  "version": "2.0.0",
  "description": "SafetyMEG EHS Platform Backend API",
  "type": "module",
  "scripts": {
    "dev": "lsof -i :8787 | grep -v COMMAND | awk '{print $2}' | xargs kill -9 2>/dev/null; tsx watch src/main.ts",
    "start": "tsx src/init-db.ts && tsx src/seed-production.ts && tsx src/main.ts",
    "workers": "tsx src/workers/start-workers.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@openrouter/sdk": "^0.3.16",
    "better-sqlite3": "^9.4.3",
    "bullmq": "^5.73.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.5",
    "resend": "^4.0.0",
    "rrule": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@types/rrule": "^2.1.7",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
