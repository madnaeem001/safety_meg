{
  "name": "youware-mobile-react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:audit": "playwright test --workers=1",
    "test:e2e:navigation-audit": "playwright test e2e/all-pages-route-and-button-navigation.spec.ts --workers=1",
    "test:e2e:surface": "playwright test e2e/route-surface-audit.spec.ts --workers=1",
    "test:e2e:critical": "playwright test e2e/route-audit-critical-paths.spec.ts e2e/domain-crud.spec.ts --workers=1",
    "test:e2e:smoke": "playwright test e2e/auth-and-dashboard.smoke.spec.ts e2e/auth-protection-and-register.spec.ts e2e/incident-routing.smoke.spec.ts e2e/scroll-reset.spec.ts e2e/shell-navigation-and-ai.spec.ts --workers=1",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:report:html": "playwright show-report playwright-report/html",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@headlessui/react": "^1.7.18",
    "ai": "^4.3.16",
    "better-sqlite3": "^12.6.2",
    "cannon-es": "^0.20.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.0.8",
    "gsap": "^3.13.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.0",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.533.0",
    "matter-js": "^0.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^6.30.1",
    "react-use": "^17.6.0",
    "recharts": "^3.6.0",
    "three": "^0.179.1",
    "zod": "^3.25.67",
    "zustand": "^4.4.7"
    
  },
  "devDependencies": {
    "@edgespark/cli": "^0.0.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/matter-js": "^0.20.0",
    "@types/node": "^24.0.14",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@youware/vite-plugin-react": "^1.0.2",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
